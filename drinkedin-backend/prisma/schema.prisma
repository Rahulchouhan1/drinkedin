generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// USER PROFILES & NETWORKING
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  bio       String?
  avatarUrl String?
  
  // A user can be a standard professional or a business owner
  role      UserRole @default(PROFESSIONAL)
  
  // Relations
  posts     Post[]
  stories   Story[]
  
  // Networking connections
  connections Connection[] @relation("UserConnections")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  PROFESSIONAL
  BUSINESS_OWNER
  ADMIN
}

model Connection {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserConnections", fields: [userId], references: [id])
  
  // The person they connected with
  connectedToId String
  
  status    ConnectionStatus @default(PENDING)
  
  createdAt DateTime @default(now())
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// -----------------------------------------------------------------------------
// BUSINESSES (Bars, Restaurants, Drink Places)
// -----------------------------------------------------------------------------

model Business {
  id          String   @id @default(uuid())
  name        String
  description String
  address     String
  
  // e.g., RESTAURANT, BAR, CLUB
  type        String
  
  // Who owns this business page?
  ownerId     String
  
  // Products they post
  products    Product[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  imageUrl    String?
  
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
}

// -----------------------------------------------------------------------------
// SOCIAL: POSTS & STORIES
// -----------------------------------------------------------------------------

model Post {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  
  // Is it about an outing, lunch, dinner, drinks, trekking?
  category  PostCategory @default(GENERAL)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
}

enum PostCategory {
  GENERAL
  LUNCH
  DINNER
  DRINKS
  TREKKING
  PARTY
}

model Story {
  id        String   @id @default(uuid())
  mediaUrl  String
  expiresAt DateTime
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
}
